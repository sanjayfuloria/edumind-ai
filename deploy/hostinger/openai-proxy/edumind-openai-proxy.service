[Unit]
Description=EduMind AI OpenAI Proxy
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/edumind-openai-proxy
EnvironmentFile=/opt/edumind-openai-proxy/.env
ExecStart=/usr/bin/node /opt/edumind-openai-proxy/server.js
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
